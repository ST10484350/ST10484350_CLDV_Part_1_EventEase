@model ST10484350_CLDV_Part_1_EventEase.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<h1>Delete Booking</h1>

<h3>Are you sure you want to delete this booking?</h3>

<div>
    <strong>@Model.CustomerName</strong> - @Model.Event?.Name at @Model.Venue?.Name
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="BookingId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>