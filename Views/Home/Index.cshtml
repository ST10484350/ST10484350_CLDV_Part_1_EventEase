@{
    ViewData["Title"] = "Dashboard";
}

<div class="ee-hero shadow-lg">
    <h2>Premium booking operations, simplified.</h2>
    <p>
        Manage venues, events, and bookings through a refined central platform built to reduce scheduling friction,
        improve visibility, and support EventEase’s growth with confidence.
    </p>
    <div class="mt-4">
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary me-2 shadow-sm">View Bookings</a>
        <a asp-controller="Venues" asp-action="Index" class="btn btn-warning text-dark shadow-sm">Explore Venues</a>
    </div>
</div>

<div class="row mb-5 px-2 g-4">
    <div class="col-md-4">
        <div class="d-flex align-items-center">
            <div class="me-3 fs-3 text-primary"><i class="bi bi-shield-check"></i></div>
            <div>
                <div class="text-uppercase fw-bold text-muted small" style="letter-spacing: 1px;">Platform Focus</div>
                <div class="fw-bold">Admin Control</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center">
            <div class="me-3 fs-3 text-success"><i class="bi bi-cpu"></i></div>
            <div>
                <div class="text-uppercase fw-bold text-muted small" style="letter-spacing: 1px;">Core Modules</div>
                <div class="fw-bold">3 Active</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center">
            <div class="me-3 fs-3 text-warning"><i class="bi bi-diagram-3"></i></div>
            <div>
                <div class="text-uppercase fw-bold text-muted small" style="letter-spacing: 1px;">Booking Logic</div>
                <div class="fw-bold">Conflict Aware</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="ee-card h-100">
            <div class="fs-1 text-primary mb-3"><i class="bi bi-building-gear"></i></div>
            <h3 class="fw-bold">Venue Portfolio</h3>
            <p class="text-muted small">Maintain venue names, locations, capacities, and presentation imagery in one polished workspace.</p>
            <a asp-controller="Venues" asp-action="Index" class="btn btn-primary w-100 mt-auto shadow-sm">Open Venues</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="ee-card h-100">
            <div class="fs-1 text-success mb-3"><i class="bi bi-stars"></i></div>
            <h3 class="fw-bold">Event Scheduling</h3>
            <p class="text-muted small">Create and manage event records with accurate guest planning, timelines, and operational clarity.</p>
            <a asp-controller="Events" asp-action="Index" class="btn btn-success w-100 mt-auto shadow-sm">Open Events</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="ee-card h-100">
            <div class="fs-1 text-warning mb-3"><i class="bi bi-calendar-check"></i></div>
            <h3 class="fw-bold">Booking Oversight</h3>
            <p class="text-muted small">Coordinate venue assignments confidently while protecting the system against overlapping bookings.</p>
            <a asp-controller="Bookings" asp-action="Index" class="btn btn-warning w-100 mt-auto text-dark shadow-sm">Open Bookings</a>
        </div>
    </div>
</div>