@model IEnumerable<ST10484350_CLDV_Part_1_EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    :root {
        --accent-color: #3b82f6;
        --bg-subtle: #f8fafc;
    }

    .venue-item {
        background: white;
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

        .venue-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
            border-color: var(--accent-color);
        }

    .img-wrapper {
        width: 280px;
        height: 180px;
        border-radius: 16px;
        overflow: hidden;
        margin: 15px;
        background: #f1f5f9;
    }

    .venue-img-horizontal {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .action-pill {
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: 0.3s;
    }

    .capacity-tag {
        background: #eff6ff;
        color: var(--accent-color);
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .create-btn-professional {
        background-color: var(--accent-color);
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        color: white;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }

        .create-btn-professional:hover {
            background-color: #2563eb;
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 8px 16px rgba(59, 130, 246, 0.3);
        }
</style>

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-1" style="color: #0f172a;">Venue Assets</h1>
            <p class="text-muted mb-0">Manage space allocations and visual identity across your infrastructure.</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <a asp-action="Create" class="create-btn-professional d-inline-block text-decoration-none">
                <i class="bi bi-plus-lg me-2"></i>New Venue
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Find a venue or city..." />
                </div>
                <button type="submit" class="btn btn-primary px-4 shadow-sm">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">Reset</a>
            </form>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div>@TempData["Error"]</div>
        </div>
    }

    <div class="venue-list">
        @foreach (var item in Model)
        {
            <div class="venue-item d-flex flex-column flex-md-row align-items-center">
                <div class="img-wrapper shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="venue-img-horizontal" alt="@item.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                            <i class="bi bi-image fs-1 opacity-25"></i>
                        </div>
                    }
                </div>
                <div class="flex-grow-1 p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="fw-bold mb-0">@item.Name</h3>
                        <span class="capacity-tag"><i class="bi bi-people-fill me-2"></i>@item.Capacity</span>
                    </div>
                    <p class="text-muted mb-4"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Location</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-outline-primary action-pill">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-outline-warning action-pill">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-outline-danger action-pill">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>